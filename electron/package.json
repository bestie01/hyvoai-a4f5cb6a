{
  "name": "hyvo-stream-studio",
  "version": "1.0.0",
  "description": "AI-powered streaming assistant for professional broadcasters",
  "homepage": "https://github.com/bestie01/hyvoai-a4f5cb6a",
  "main": "src/index.js",
  "author": {
    "name": "Hyvo",
    "email": "support@hyvo.app"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder --win --mac --linux --publish never",
    "publish:win": "electron-builder --win --publish always",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:linux": "electron-builder --linux --publish always",
    "publish:all": "electron-builder --win --mac --linux --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.hyvo.streamstudio",
    "productName": "Hyvo Stream Studio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "app/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "bestie01",
      "repo": "hyvoai-a4f5cb6a",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "app/icons/appIcon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "app/icons/appIcon.ico",
      "uninstallerIcon": "app/icons/appIcon.ico",
      "installerHeaderIcon": "app/icons/appIcon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "app/icons/appIcon.png",
      "category": "public.app-category.video",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "app/icons/appIcon.png",
      "category": "AudioVideo",
      "maintainer": "Hyvo <support@hyvo.app>"
    }
  }
}
